{
  "name": "agent-pkg",
  "version": "0.1.0",
  "description": "Wrapper around skills CLI for Cursor and Claude with agents and commands config",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agent-pkg": "./bin/agent-pkg.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli.ts",
    "start": "node bin/agent-pkg.mjs",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cursor",
    "claude",
    "skills",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
